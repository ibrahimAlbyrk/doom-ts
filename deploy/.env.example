# DOOM-TS deploy config. Copy to deploy/.env (gitignored) and edit, or just export these in your
# shell / set them in the systemd unit. All have sane defaults; none are strictly required.

# ── Server (server/prod.ts) ──────────────────────────────────────────────────────────
# Port the single prod process listens on (client + Colyseus ws + /matchmake). Default 2567.
PORT=2567
# Bind address. 0.0.0.0 so friends can reach it; 127.0.0.1 to only allow a local reverse proxy.
HOST=0.0.0.0
# Optional: override where the built client lives. Default: <repo>/dist .
# CLIENT_DIR=/opt/doom/dist

# ── Caddy (deploy/Caddyfile, deploy/docker-compose.yml) ──────────────────────────────
# Public hostname Caddy gets a TLS cert for. Use a free name that maps to your IP:
#   <dashed-ip>.sslip.io  (203.0.113.5 -> 203-0-113-5.sslip.io), a DuckDNS name, or your domain.
DOOM_HOST=203-0-113-5.sslip.io
# Where Caddy proxies to. localhost:2567 for a host/systemd install; doom:2567 under compose.
DOOM_UPSTREAM=localhost:2567

# ── Client build-time override (optional) ────────────────────────────────────────────
# Force the client to connect to a specific match-server URL instead of deriving it from the
# page origin. Leave UNSET for the normal single-host deploy (client uses same origin -> wss).
# Set only if the client is hosted separately from the server.
#   VITE_MP_SERVER_URL=wss://203-0-113-5.sslip.io
